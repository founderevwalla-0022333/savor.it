<svg xmlns="http://www.w3.org/2000/svg" width="800" height="500" viewBox="0 0 800 500">
  <defs>
    <linearGradient id="bg2" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0d0d1a"/>
      <stop offset="50%" style="stop-color:#1a0d2e"/>
      <stop offset="100%" style="stop-color:#0d1a2e"/>
    </linearGradient>
    <linearGradient id="rgb1" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#ff00ff;stop-opacity:0.4"/>
      <stop offset="50%" style="stop-color:#8B5CF6;stop-opacity:0.4"/>
      <stop offset="100%" style="stop-color:#00ffff;stop-opacity:0.4"/>
    </linearGradient>
  </defs>
  <rect width="800" height="500" fill="url(#bg2)"/>
  <rect x="100" y="80" width="600" height="300" rx="12" fill="#1a1a2e" opacity="0.6"/>
  <rect x="150" y="120" width="200" height="120" rx="6" fill="url(#rgb1)"/>
  <rect x="370" y="120" width="200" height="120" rx="6" fill="url(#rgb1)" opacity="0.8"/>
  <rect x="200" y="320" width="400" height="20" rx="4" fill="#2a1a3e" opacity="0.7"/>
  <circle cx="300" cy="200" r="40" fill="#8B5CF6" opacity="0.15"/>
  <circle cx="500" cy="180" r="35" fill="#4F8CFF" opacity="0.15"/>
  <text x="400" y="450" text-anchor="middle" fill="#F5F5F7" font-family="Inter,sans-serif" font-size="18" font-weight="600" opacity="0.7">Gaming Battlestation</text>
</svg>
