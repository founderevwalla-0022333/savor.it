<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="750" viewBox="0 0 1200 750">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1a1a2e"/>
      <stop offset="50%" style="stop-color:#16213e"/>
      <stop offset="100%" style="stop-color:#0f3460"/>
    </linearGradient>
    <linearGradient id="glow" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#8B5CF6;stop-opacity:0.3"/>
      <stop offset="100%" style="stop-color:#4F8CFF;stop-opacity:0.3"/>
    </linearGradient>
  </defs>
  <rect width="1200" height="750" fill="url(#bg)"/>
  <rect x="200" y="200" width="800" height="50" rx="8" fill="#1c1c2e" opacity="0.8"/>
  <rect x="300" y="300" width="600" height="200" rx="12" fill="#1c1c2e" opacity="0.6"/>
  <circle cx="400" cy="400" r="80" fill="url(#glow)"/>
  <circle cx="800" cy="350" r="60" fill="url(#glow)" opacity="0.5"/>
  <rect x="250" y="500" width="700" height="8" rx="4" fill="#8B5CF6" opacity="0.2"/>
  <rect x="350" y="520" width="500" height="4" rx="2" fill="#4F8CFF" opacity="0.15"/>
  <text x="600" y="680" text-anchor="middle" fill="#F5F5F7" font-family="Inter,sans-serif" font-size="24" font-weight="700" opacity="0.6">Premium Gaming &amp; Coding Setup</text>
</svg>
